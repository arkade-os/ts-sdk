{
  "name": "arkade-monorepo",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=10.25.0 <11"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm run test:integration:ts-sdk && pnpm run test:integration:boltz-swap",
    "test:integration:ts-sdk": "bash scripts/regtest.sh ts-sdk cycle",
    "test:integration:boltz-swap": "bash scripts/regtest.sh boltz-swap cycle",
    "lint": "pnpm -r lint",
    "release": "bash scripts/release.sh all",
    "release:ts-sdk": "bash scripts/release.sh ts-sdk",
    "release:boltz-swap": "bash scripts/release.sh boltz-swap",
    "regtest:up:ts-sdk": "bash scripts/regtest.sh ts-sdk up",
    "regtest:up:boltz-swap": "bash scripts/regtest.sh boltz-swap up",
    "regtest:setup:ts-sdk": "bash scripts/regtest.sh ts-sdk setup",
    "regtest:setup:boltz-swap": "bash scripts/regtest.sh boltz-swap setup",
    "regtest:test:ts-sdk": "bash scripts/regtest.sh ts-sdk test",
    "regtest:test:boltz-swap": "bash scripts/regtest.sh boltz-swap test",
    "regtest:down:ts-sdk": "bash scripts/regtest.sh ts-sdk down",
    "regtest:down:boltz-swap": "bash scripts/regtest.sh boltz-swap down",
    "regtest:reset:ts-sdk": "bash scripts/regtest.sh ts-sdk reset",
    "regtest:reset:boltz-swap": "bash scripts/regtest.sh boltz-swap reset",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "24.3.1",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.35.0",
    "husky": "9.1.7",
    "prettier": "3.6.2",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "brace-expansion": "^2.0.2",
      "minimatch": "9.0.3"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "canvas",
      "sqlite3",
      "@arkade-os/sdk"
    ],
    "ignoredBuiltDependencies": [
      "canvas",
      "esbuild"
    ]
  }
}
