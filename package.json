{
    "name": "arkade-monorepo",
    "private": true,
    "packageManager": "pnpm@10.25.0",
    "engines": {
        "node": ">=24.15.0 <25",
        "pnpm": ">=10.25.0 <11"
    },
    "scripts": {
        "build": "pnpm -r build",
        "test": "pnpm run test:unit && pnpm run test:integration",
        "test:unit": "pnpm -r test:unit",
        "test:integration": "pnpm run test:integration:ts-sdk && pnpm run test:integration:boltz-swap && pnpm run test:integration:banco",
        "test:integration:ts-sdk": "bash scripts/regtest.sh ts-sdk cycle",
        "test:integration:boltz-swap": "bash scripts/regtest.sh boltz-swap cycle",
        "test:integration:banco": "bash scripts/regtest.sh banco cycle",
        "lint": "pnpm -r lint",
        "release": "bash scripts/release.sh",
        "release:dry-run": "bash scripts/release.sh --dry-run",
        "release:cleanup": "bash scripts/release.sh --cleanup",
        "regtest:up:ts-sdk": "bash scripts/regtest.sh ts-sdk up",
        "regtest:up:boltz-swap": "bash scripts/regtest.sh boltz-swap up",
        "regtest:up:banco": "bash scripts/regtest.sh banco up",
        "regtest:setup:ts-sdk": "bash scripts/regtest.sh ts-sdk setup",
        "regtest:setup:boltz-swap": "bash scripts/regtest.sh boltz-swap setup",
        "regtest:setup:banco": "bash scripts/regtest.sh banco setup",
        "regtest:test:ts-sdk": "bash scripts/regtest.sh ts-sdk test",
        "regtest:test:boltz-swap": "bash scripts/regtest.sh boltz-swap test",
        "regtest:test:banco": "bash scripts/regtest.sh banco test",
        "regtest:down:ts-sdk": "bash scripts/regtest.sh ts-sdk down",
        "regtest:down:boltz-swap": "bash scripts/regtest.sh boltz-swap down",
        "regtest:down:banco": "bash scripts/regtest.sh banco down",
        "regtest:reset:ts-sdk": "bash scripts/regtest.sh ts-sdk reset",
        "regtest:reset:boltz-swap": "bash scripts/regtest.sh boltz-swap reset",
        "regtest:reset:banco": "bash scripts/regtest.sh banco reset",
        "prepare": "husky"
    },
    "devDependencies": {
        "@types/node": "24.3.1",
        "eventsource": "4.1.0",
        "fake-indexeddb": "6.2.5",
        "husky": "9.1.7",
        "prettier": "3.6.2",
        "tsup": "^8.5.0",
        "typescript": "5.9.2",
        "vitest": "3.2.4"
    }
}
