{
    "name": "@arkade-os/boltz-swap",
    "version": "0.3.16",
    "type": "module",
    "description": "A production-ready TypeScript package that brings Boltz submarine-swaps to Arkade.",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.cjs"
            }
        },
        "./expo": {
            "import": {
                "types": "./dist/expo/index.d.ts",
                "default": "./dist/expo/index.js"
            },
            "require": {
                "types": "./dist/expo/index.d.ts",
                "default": "./dist/expo/index.cjs"
            }
        },
        "./repositories/sqlite": {
            "import": {
                "types": "./dist/repositories/sqlite/index.d.ts",
                "default": "./dist/repositories/sqlite/index.js"
            },
            "require": {
                "types": "./dist/repositories/sqlite/index.d.ts",
                "default": "./dist/repositories/sqlite/index.cjs"
            }
        },
        "./repositories/realm": {
            "import": {
                "types": "./dist/repositories/realm/index.d.ts",
                "default": "./dist/repositories/realm/index.js"
            },
            "require": {
                "types": "./dist/repositories/realm/index.d.ts",
                "default": "./dist/repositories/realm/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts src/expo/index.ts src/repositories/sqlite/index.ts src/repositories/realm/index.ts --format esm,cjs --dts --clean",
        "format": "prettier --write src test",
        "lint": "prettier --check src test",
        "prepack": "pnpm run build",
        "test": "vitest run",
        "test:unit": "vitest run --exclude test/e2e",
        "test:integration": "vitest run test/e2e/**",
        "test:setup-docker": "node test/e2e/setup.mjs",
        "test:integration-docker": "vitest run test/e2e/**",
        "release": "pnpm run build && bash scripts/release.sh",
        "release:dry-run": "bash scripts/release.sh --dry-run",
        "release:cleanup": "bash scripts/release.sh --cleanup",
        "regtest:start": "./regtest/start-env.sh",
        "regtest:stop": "./regtest/stop-env.sh",
        "regtest:clean": "./regtest/clean-env.sh",
        "regtest": "pnpm regtest:clean && pnpm regtest:start && pnpm test:setup-docker"
    },
    "keywords": [
        "arkade",
        "boltz",
        "swap",
        "lightning",
        "bitcoin"
    ],
    "author": "Arkade-OS",
    "license": "MIT",
    "dependencies": {
        "@arkade-os/sdk": "0.4.16",
        "@noble/hashes": "2.0.1",
        "@scure/base": "2.0.0",
        "@scure/btc-signer": "2.0.1",
        "bip68": "^1.0.4",
        "@noble/curves": "^2.0.1",
        "light-bolt11-decoder": "3.2.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.35.0",
        "@types/node": "^24.3.1",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.43.0",
        "@typescript-eslint/parser": "^8.43.0",
        "eslint": "^9.35.0",
        "eventsource": "^4.1.0",
        "fake-indexeddb": "^6.0.0",
        "prettier": "3.6.2",
        "tsup": "^8.5.0",
        "typescript": "^5.9.2",
        "vite": "7.1.11",
        "vitest": "^3.2.4"
    },
    "engines": {
        "node": ">=22.12.0 <23",
        "pnpm": ">=10.25.0 <11"
    },
    "publishConfig": {
        "access": "public"
    },
    "packageManager": "pnpm@10.25.0",
    "pnpm": {
        "onlyBuiltDependencies": [
            "sqlite3",
            "@arkade-os/sdk"
        ],
        "ignoredBuiltDependencies": [
            "canvas",
            "esbuild"
        ]
    }
}
