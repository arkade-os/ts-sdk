{
    "extends": "../../config/tsconfig.base.json",
    "compilerOptions": {
        "lib": ["es2022", "dom"],
        "types": ["node"],
        "outDir": "./dist",
        "declaration": true,
        "sourceMap": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true
    },
    "include": ["src/**/*.ts", "../../config/types/**/*.d.ts"],
    "exclude": ["node_modules", "dist", "test", "src/repositories/realm"]
}
